# Public build-time variables. Copy to `.env.local` for local overrides; set them
# in the Cloudflare Pages / GitHub Actions environment for deploys. All are
# optional — the site builds and runs without any of them.

# Canonical site origin, used to resolve absolute OG / canonical / sitemap URLs.
# Defaults to https://fusionspace.co when unset.
NEXT_PUBLIC_SITE_URL=https://fusionspace.co
